# Unreal Engine project .gitignore

# Visual Studio / Rider user-specific files
.vs/
.idea/
*.VC.db
*.VC.opendb
*.suo
*.opensdf
*.sdf

# Project files generated by the engine
*.sln
*.slnx
*.xcodeproj
*.xcworkspace

# Compiled binaries / libraries
*.dll
*.exe
*.lib
*.a
*.so
*.dylib
*.obj
*.o
*.pdb
*.pch
*.gch

# Engine-generated folders (regenerable, must NOT be committed)
Binaries/
Plugins/*/Binaries/
Intermediate/
Plugins/*/Intermediate/
DerivedDataCache/
Saved/

# Build outputs
Build/
